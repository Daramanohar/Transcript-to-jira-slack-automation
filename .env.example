# Copy this file to .env and fill in your own values before running.

# Google Gemini (free tier from Google AI Studio). Optional: without it the
# automation falls back to a deterministic extractor.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER=gemini

# Jira Cloud
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_PROJECT_KEY=KAN
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_ISSUE_TYPE=Task

# Slack (bot token with chat:write scope)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL=your_channel_id_here

# Used in generated links and reports
ORGANIZATION_NAME=Origin Medical